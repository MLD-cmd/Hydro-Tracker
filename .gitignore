# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Claude Code / local MCP tooling config (references the Supabase project)
.mcp.json

# AI-generated planning docs
docs/superpowers/

# Dart DevTools (auto-generated)
devtools_options.yaml

# Secrets / environment — never commit Supabase service_role keys, DB
# passwords, or access tokens. (The anon/publishable key in
# lib/config/supabase_config.dart is safe by design; RLS guards the data.)
.env
.env.*
*.env

# Supabase CLI local state (kept out even if the CLI is added later)
supabase/.temp/
supabase/.branches/
supabase/.env

# Local-only docs & generated diagrams (not part of the app)
DEMO_SCRIPT.md
supabase_erd.png
supabase_schema.png
